# Template for a real deployment - copy this file, rename it, fill in
# your own values, and load it however your hosting platform expects
# (a mounted env file, secret manager, CI/CD variable injection, ...).
# This project is platform-neutral: nothing here assumes any specific
# cloud provider or orchestrator.
#
# Every value below is a placeholder. Never commit the filled-in copy of
# this file anywhere - treat it exactly like .env/.env.docker (both
# already gitignored). See docs/DEPLOYMENT.md for the full runbook this
# file is meant to be read alongside.

# ============================================================
# Required
# ============================================================

# Maps API keys to user ids for the X-API-Key auth dependency
# (app/services/auth.py). The app refuses to start with this unset,
# empty, or malformed - see app/config.py's _parse_api_keys for the
# exact validation rules, none of which ever echo a raw key value back.
# Format: comma-separated "key:user_id" pairs, one per user, each key
# unique. Generate real random keys, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Consider including one dedicated, isolated entry here for smoke
# testing after each deploy (see docker/smoke_test.ps1's -SmokeTestApiKey
# and docs/DEPLOYMENT.md's smoke-test section) - e.g.
# "<generated-key>:smoke_test_user" - never reuse a real user's key for
# that purpose.
API_KEYS=

# Where task data is persisted. PostgreSQL is the RECOMMENDED choice for
# a public deployment (concurrent access, real backups, no single-file
# locking) - see docs/DEPLOYMENT.md's "PostgreSQL setup" section for the
# full procedure. SQLite (sqlite:///./tasks.db, or a container path like
# sqlite:////data/tasks.db) remains fully supported and is still the
# zero-config default for local development, but is not the recommended
# choice for a public deployment.
DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<database>

# ============================================================
# Strongly recommended
# ============================================================

# Bounded timeout, in seconds, for GET /ready's database/schema check.
# Must be a positive number - the app refuses to start otherwise. The
# default (2.0) is deliberately small: a readiness probe should fail
# fast, not block an orchestrator's health-check loop. See
# app/services/readiness.py and docs/DEPLOYMENT.md's "Health vs.
# readiness" section.
READY_CHECK_TIMEOUT_SECONDS=2.0

# Log verbosity for the whole app - DEBUG, INFO, WARNING, ERROR, or
# CRITICAL. INFO is the recommended default for a real deployment - see
# docs/DEPLOYMENT.md's "Logs" section for exactly what is (and is never)
# written to container stdout/stderr.
LOG_LEVEL=INFO

# ============================================================
# Agent decision provider - pick one
# ============================================================

# "rule_based" (default, no external calls, always available - the mode
# docs/DEPLOYMENT.md's smoke-test procedure exercises), "anthropic"
# (needs ANTHROPIC_API_KEY below), or "ollama" (needs a reachable Ollama
# server - not something this app runs for you). Both LLM providers
# automatically fall back to rule_based on any failure.
AGENT_DECISION_PROVIDER=rule_based

# Required only if AGENT_DECISION_PROVIDER=anthropic. Never commit a
# real value.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_TIMEOUT_SECONDS=10.0
ANTHROPIC_MAX_RETRIES=2

# Required only if AGENT_DECISION_PROVIDER=ollama - this app never runs
# Ollama itself, it only calls out to an existing server you operate.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=30.0

# Whether POST /agent/execute may plan and run up to AGENT_MAX_PLAN_STEPS
# existing tools in one request. Only takes effect when
# AGENT_DECISION_PROVIDER=ollama; rule_based and anthropic stay
# single-step only. delete_task is never allowed inside a multi-step
# plan - it always requires its normal confirmation flow.
AGENT_MULTI_STEP_PLANNING=false
# AGENT_MAX_PLAN_STEPS=3

# ============================================================
# Conversation state TTLs (seconds) - all must be positive integers
# ============================================================
CONFIRMATION_TTL_SECONDS=300
CLARIFICATION_TTL_SECONDS=900
CONTEXT_TTL_SECONDS=7200

# ============================================================
# Request handling
# ============================================================

# Maximum size, in bytes, of any incoming request body. A larger body
# gets a 413 before routing/auth/parsing ever run.
MAX_REQUEST_BODY_BYTES=65536

OPEN_METEO_TIMEOUT_SECONDS=5.0

# In-memory, per-user, fixed-window rate limit on POST /agent/execute -
# an abuse/accident guard, NOT a security boundary, and only correct
# with a single worker (see docs/DEPLOYMENT.md's "Single-worker
# limitation" section - this is exactly why the production server
# command stays at --workers 1).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
