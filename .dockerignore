# Git
.git/
.gitignore

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/

# Secrets / local env files - never baked into the image
.env
.env.docker
.env.demo
.env.vercel
.env.*.local

# Local databases - the real dev DB must never enter the build context
tasks.db
auth_test.db
*.db
*.db-journal

# Tests / evaluation code+reports - not needed at runtime
tests/
evals/

# Docker recipe files - not needed inside the image itself
Dockerfile
compose.yaml
compose.demo.yaml
docker/smoke_test.ps1
docker-data/

# Vercel-only files/local CLI state - never needed inside the Docker image
vercel.json
.vercel/

# Misc
README.md
.claude/
