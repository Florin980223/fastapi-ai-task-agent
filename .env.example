# Copy this file to .env and fill in your own values.
# Never commit .env (it's already in .gitignore).

# Required only if AGENT_DECISION_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Which Claude model the Anthropic decision provider uses.
ANTHROPIC_MODEL=claude-opus-4-8

# Where the local Ollama server is running, and which model to use.
# Only used if AGENT_DECISION_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# "rule_based" (default, no external calls), "anthropic" (asks Claude to
# pick a tool), or "ollama" (asks a local Ollama model to pick a tool) -
# both LLM providers automatically fall back to rule_based on any failure.
AGENT_DECISION_PROVIDER=rule_based

# Whether POST /agent/execute may plan and run up to 3 existing tools in
# one request (e.g. "Create a task to buy milk and then show me all
# tasks"). Only takes effect when AGENT_DECISION_PROVIDER=ollama;
# rule_based and anthropic stay single-step only. delete_task is never
# allowed inside a multi-step plan - it always requires its normal
# confirmation flow.
AGENT_MULTI_STEP_PLANNING=false

# Where task data is persisted. Defaults to a local SQLite file.
DATABASE_URL=sqlite:///./tasks.db

# How long (in seconds) pending clarifications, pending destructive-
# action confirmations, and remembered task context ("it"/"that one")
# stay valid before a follow-up reply is treated as unrelated to them.
# All three are persisted in the same SQLite database as tasks (see
# app/services/conversation_memory.py) and survive app/container
# restarts. Must be positive integers - the app refuses to start
# otherwise.
CONFIRMATION_TTL_SECONDS=300
CLARIFICATION_TTL_SECONDS=900
CONTEXT_TTL_SECONDS=7200

# Log verbosity for the whole app - DEBUG, INFO, WARNING, ERROR, or
# CRITICAL. See "Reliability & request handling" in README.md for the
# log line format and where to find it.
LOG_LEVEL=INFO

# Maximum size, in bytes, of any incoming request body. Enforced before
# routing/auth/parsing ever run; a larger body gets a 413. 64 KiB is
# comfortably above any legitimate payload this API accepts.
MAX_REQUEST_BODY_BYTES=65536

# Explicit connect/read timeouts (seconds) for every external HTTP call
# this app makes.
OPEN_METEO_TIMEOUT_SECONDS=5.0
OLLAMA_TIMEOUT_SECONDS=30.0
ANTHROPIC_TIMEOUT_SECONDS=10.0

# Bounded retries the Anthropic SDK performs on its own (connection
# errors, 408/409/429/5xx only - never a 4xx). 2 matches the SDK's own
# default; made explicit/configurable here instead of an invisible one.
ANTHROPIC_MAX_RETRIES=2

# Minimal in-memory, per-user rate limit on POST /agent/execute - an
# abuse/accident guard, not a security boundary, and only correct with
# a single worker (see "Rate limiting" in README.md).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Required. Maps API keys to user ids for the X-API-Key auth dependency
# (app/services/auth.py) - required for /tasks, POST /agent/execute, and
# GET /agent/runs[/{run_id}]. Format: comma-separated "key:user_id"
# pairs, each user needs a distinct key. At least one pair is required -
# the app refuses to start with API_KEYS unset or empty.
#
# The values below are local-dev placeholders only. Generate your own
# random keys for anything beyond local development
# (e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`),
# and never commit real keys - this file is a template, not read directly.
#
# If you have a tasks.db from before authentication was added, its rows
# are preserved but become inaccessible via the API after upgrading (they
# are assigned the reserved user_id "__unmigrated__", which can never
# match a real configured user). Either delete tasks.db to start clean,
# or manually run:
#   UPDATE tasks SET user_id = '<your dev user id>' WHERE user_id = '__unmigrated__';
#   UPDATE agent_runs SET user_id = '<your dev user id>' WHERE user_id = '__unmigrated__';
# to reclaim them.
API_KEYS=devkey-alice:alice,devkey-bob:bob
