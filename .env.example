# Copy this file to .env and fill in your own values.
# Never commit .env (it's already in .gitignore).

# Required only if AGENT_DECISION_PROVIDER=anthropic.
ANTHROPIC_API_KEY=

# Which Claude model the Anthropic decision provider uses.
ANTHROPIC_MODEL=claude-opus-4-8

# Where the local Ollama server is running, and which model to use.
# Only used if AGENT_DECISION_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b

# "rule_based" (default, no external calls), "anthropic" (asks Claude to
# pick a tool), or "ollama" (asks a local Ollama model to pick a tool) -
# both LLM providers automatically fall back to rule_based on any failure.
AGENT_DECISION_PROVIDER=rule_based

# Whether POST /agent/execute may plan and run up to 3 existing tools in
# one request (e.g. "Create a task to buy milk and then show me all
# tasks"). Only takes effect when AGENT_DECISION_PROVIDER=ollama;
# rule_based and anthropic stay single-step only. delete_task is never
# allowed inside a multi-step plan - it always requires its normal
# confirmation flow.
AGENT_MULTI_STEP_PLANNING=false

# Where task data is persisted. Defaults to a local SQLite file.
DATABASE_URL=sqlite:///./tasks.db
