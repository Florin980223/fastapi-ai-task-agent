# Copy this file to .env.demo and fill in your own values (PowerShell):
#   Copy-Item .env.demo.example .env.demo
#
# .env.demo is gitignored AND dockerignored - never commit it, and it
# is never sent into any Docker build context. docker/demo_start.ps1
# fails fast with a clear error if it's missing - that's intentional,
# it forces this copy step. See docs/LOCAL_DEMO.md for the full
# walkthrough, including how to generate real random values for the
# placeholders below.
#
# This is a completely separate, isolated identity set from your own
# normal dev .env/.env.docker - never reuse your real API key, your
# real user_id, or your real Postgres password here.

# Required. Dedicated demo database/role - must stay exactly
# "taskagent_demo" (docker/demo_seed.py and the reset/cleanup scripts
# refuse to operate on anything else, by design).
POSTGRES_USER=taskagent_demo
POSTGRES_PASSWORD=REPLACE-ME-generate-your-own
POSTGRES_DB=taskagent_demo

# Required. Must match POSTGRES_USER/PASSWORD/DB above exactly -
# nothing keeps these two in sync for you. "postgres-demo" is the
# Compose-internal service hostname, only reachable from app-demo, not
# the host (use 127.0.0.1:55434 from the host instead, e.g. for
# docker/demo_seed.py).
DATABASE_URL=postgresql+psycopg://taskagent_demo:REPLACE-ME-generate-your-own@postgres-demo:5432/taskagent_demo

# Required. Two dedicated demo identities (never your real dev
# user_id, a CI user_id, or a migration/smoke-test user_id) - this
# lets docker/demo_verify.ps1 prove per-user isolation with zero extra
# setup. Generate real random keys yourself, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Never print/paste a generated key anywhere except straight into this
# file or the Web UI's key field - see docs/LOCAL_DEMO.md.
API_KEYS=REPLACE-ME-demo-key-a:demo_user_a,REPLACE-ME-demo-key-b:demo_user_b

# Guaranteed-offline default - no external calls, no API key needed
# beyond the ones above. See docs/LOCAL_DEMO.md if you want to
# optionally try a local Ollama model instead once the demo works.
AGENT_DECISION_PROVIDER=rule_based
AGENT_MULTI_STEP_PLANNING=false

LOG_LEVEL=INFO
