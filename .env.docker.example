# Copy this file to .env.docker and adjust as needed (PowerShell):
#   Copy-Item .env.docker.example .env.docker
#
# .env.docker is gitignored - never commit it. `docker compose up`
# fails fast with a clear "file not found" error if it's missing -
# that's intentional, it forces this copy step. Values below are
# local-dev/demo placeholders only, matching the same convention as
# the project's own .env.example - never real secrets.

# Required. Maps API keys to user ids (X-API-Key header) - the app
# refuses to start with API_KEYS unset or empty. Format: comma-separated
# "key:user_id" pairs, one per user. Generate your own random keys for
# anything beyond a local demo:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=devkey-alice:alice,devkey-bob:bob

# Docker demo defaults: fully offline, no external services required.
AGENT_DECISION_PROVIDER=rule_based
AGENT_MULTI_STEP_PLANNING=false

# SQLite path inside the container. Matches the Dockerfile default and
# the named volume mounted at /data in compose.yaml - don't change this
# unless you also change the volume mount path. This is never the host
# project's real ./tasks.db.
DATABASE_URL=sqlite:////data/tasks.db

# --- Optional: switch to a local Ollama model instead of rule_based ---
# Ollama itself is NOT part of this compose stack - install and run it
# on the host (https://ollama.com), then uncomment below.
# host.docker.internal reaches the host machine from inside the
# container on Docker Desktop (Windows/Mac); compose.yaml also adds an
# extra_hosts entry so this works on native Linux too.
#
# AGENT_DECISION_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen3:4b
# AGENT_MULTI_STEP_PLANNING=true

# --- Optional: switch to the Anthropic decision provider instead ---
# AGENT_DECISION_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Optional: PostgreSQL instead of SQLite (see README.md's
# "PostgreSQL (optional)" section for the full setup/startup procedure)
# ---
# Fake local-dev placeholders only - generate your own if you actually
# care about this instance's security:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# These three are read directly by the official postgres image's own
# entrypoint script (via compose.yaml's `postgres` service env_file) -
# it refuses to start without a password set. Never starts unless you
# run `docker compose --profile postgres ...` explicitly.
#
# POSTGRES_USER=taskagent
# POSTGRES_PASSWORD=devpassword-change-me
# POSTGRES_DB=taskagent
#
# Then replace the DATABASE_URL line above with this one (comment out
# the sqlite:// line and uncomment this) - `postgres` is the
# Compose-internal service hostname, only reachable from the `app`
# container, not the host. IMPORTANT: keep the password here in sync
# with POSTGRES_PASSWORD above - they must be the same value, and
# nothing automatically keeps them in sync for you.
#
# DATABASE_URL=postgresql+psycopg://taskagent:devpassword-change-me@postgres:5432/taskagent

# --- Reliability & request-handling defaults (see README.md) ---
# All of these already have the same sane defaults built in - only
# uncomment/change one if you actually want something different for
# this container.
# LOG_LEVEL=INFO
# MAX_REQUEST_BODY_BYTES=65536
# OPEN_METEO_TIMEOUT_SECONDS=5.0
# OLLAMA_TIMEOUT_SECONDS=30.0
# ANTHROPIC_TIMEOUT_SECONDS=10.0
# ANTHROPIC_MAX_RETRIES=2
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=120
# RATE_LIMIT_WINDOW_SECONDS=60
