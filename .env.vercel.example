# Placeholder-only reference for a future Vercel + Neon deployment - see
# docs/VERCEL.md for the full runbook. This feature does not create any
# Vercel project, Neon project, or deployment - this file is not copied
# to a real .env.vercel and is not read by any code; it exists purely
# to document what the future Production environment variables would be.
#
# Never commit real values anywhere. Configure these directly in
# Vercel's own Production environment variable settings when a real
# deployment is actually created - never in a file in this repository.

# ============================================================
# Runtime (Vercel Production environment variables) - required
# ============================================================

# The Neon POOLED connection string (hostname contains "-pooler").
# This is the ONLY database URL ever configured in the Vercel runtime's
# environment - see "Migration-only" section below for what must never
# be set here.
DATABASE_URL=postgresql+psycopg://<user>:<password>@<project>-pooler.<region>.aws.neon.tech/<database>?sslmode=require

# One dedicated, disposable demo API key - never a real user's key, never
# reused from local/CI/other demos.
API_KEYS=<generated-demo-key>:demo_user

# Guaranteed-offline, zero-cost defaults - no Ollama, no Anthropic, no
# Vercel AI Gateway, no paid model API of any kind.
AGENT_DECISION_PROVIDER=rule_based
AGENT_MULTI_STEP_PLANNING=false

# Opts into the NullPool + PgBouncer-safe connection settings in
# app/database.py - see docs/VERCEL.md's "SQLAlchemy and Neon pooling
# strategy" section. Never set this locally/in Docker/in CI.
DB_POOL_MODE=serverless

READY_CHECK_TIMEOUT_SECONDS=2.0

# In-memory, per-instance only under Vercel - NOT a cross-instance
# guarantee. See docs/VERCEL.md's "Rate-limit limitation" section - this
# is honestly documented as best-effort, never claimed as global/
# production-grade rate limiting. API key authentication remains the
# real security boundary.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================
# Migration-only - NEVER set these in the Vercel runtime's environment
# ============================================================

# The Neon DIRECT connection string (hostname does NOT contain
# "-pooler"). Used only for a human-run `python -m alembic upgrade head`
# / `alembic check` against the real Neon database - see docs/VERCEL.md's
# "Future Neon creation and migration procedure". Read only by
# alembic/env.py - never by app/config.py, app/database.py, or
# app/main.py, and never present in the deployed application's own
# configured environment variables.
# MIGRATION_DATABASE_URL=postgresql+psycopg://<user>:<password>@<project>.<region>.aws.neon.tech/<database>?sslmode=require

# Set to "production" only for the duration of a real migration command
# against Neon, alongside MIGRATION_DATABASE_URL above. Unset (the
# default) everywhere else - every local/Docker/CI Alembic invocation
# relies on this staying unset to keep using DATABASE_URL exactly as
# before this feature existed.
# MIGRATION_MODE=production
